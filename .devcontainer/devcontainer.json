{
  "name": "Flutter Development - Prebuilds Disabled",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/flutter:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ]
    }
  },
  "forwardPorts": [3000, 8080],
  "onCreateCommand": "flutter doctor",
  "postCreateCommand": "flutter pub get",
  "remoteUser": "vscode",
  "codespaces": {
    "prebuilds": false,
    "enablePrebuilds": false
  },
  "settings": {
    "prebuildCommand": "echo 'Prebuilds disabled'",
    "enablePrebuilds": false
  }
}